<%- include("../partials/navbar.ejs", { title: title }) %>
<%- include("../partials/flash.ejs") %>

<div id="dashboard-app" class="max-w-6xl mx-auto py-16 px-6">

  <!-- Header -->
  <div class="flex justify-between items-center mb-12">
    <h1 class="text-4xl font-extrabold tracking-tight text-pink-300">
      Dashboard
    </h1>

    <a
      href="/ads/new"
      class="px-5 py-3 rounded-lg text-pink-300 border border-pink-500 bg-slate-900
             hover:bg-slate-800 transition"
    >
      + Create new ad
    </a>
  </div>

  <!-- Stats -->
  <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-16">
    <div class="p-6 rounded-xl bg-slate-900 border border-slate-800 text-slate-200">
      <p class="text-sm text-slate-400">Live ads</p>
      <p class="text-3xl font-bold"><%= stats.live || 0 %></p>
    </div>

    <div class="p-6 rounded-xl bg-slate-900 border border-slate-800 text-slate-200">
      <p class="text-sm text-slate-400">Drafts</p>
      <p class="text-3xl font-bold"><%= stats.drafts || 0 %></p>
    </div>

    <div class="p-6 rounded-xl bg-slate-900 border border-slate-800 text-slate-200">
      <p class="text-sm text-slate-400">Pending</p>
      <p class="text-3xl font-bold"><%= stats.pending || 0 %></p>
    </div>
  </div>

  <!-- Empty state -->
  <% if (!ads || ads.length === 0) { %>
    <div class="p-10 rounded-2xl bg-slate-900 border border-slate-800 text-center">
      <p class="text-slate-400 text-lg">
        You haven’t posted any ads yet.
      </p>
    </div>
  <% } else { %>

    <!-- Ads list -->
    <div class="flex flex-col gap-8">
      <% ads.forEach(ad => { %>
        <div class="p-7 rounded-2xl bg-slate-900 border border-slate-800 text-slate-200">

          <div class="flex justify-between items-start mb-3">
            <h3 class="text-2xl font-semibold">
              <%= ad.title %>
            </h3>

            <span class="text-xs px-3 py-1 rounded-full border
              <% if (ad.status === 'approved') { %>
                bg-green-900 text-green-300 border-green-700
              <% } else if (ad.status === 'draft') { %>
                bg-slate-800 text-slate-300 border-slate-700
              <% } else { %>
                bg-yellow-900 text-yellow-300 border-yellow-700
              <% } %>">
              <%= ad.status %>
            </span>
          </div>

          <p class="text-sm text-slate-400 mb-2">
            <%= ad.city_name %> · <%= ad.category_name %>
            <% if (ad.subcategory_name) { %>
              / <%= ad.subcategory_name %>
            <% } %>
          </p>

          <p class="text-slate-300 line-clamp-2 mb-5">
            <%= ad.body %>
          </p>

          <!-- Actions -->
          <div class="flex gap-6 text-sm items-center">
            <a href="/ads/<%= ad.id %>/edit" class="text-slate-400 hover:text-pink-300">Edit</a>

            <delete-ad
              ad-id="<%= ad.id %>"
              action="/ads/<%= ad.id %>/delete"
              csrf-token="<%= csrfToken %>"
            ></delete-ad>
          </div>

        </div>
      <% }) %>
    </div>
  <% } %>

</div>

<!-- Vue entry -->
<script type="module" src="/js/dashboard.js"></script>

<%- include("../partials/footer.ejs") %>

