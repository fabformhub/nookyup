<div class="space-y-8">

  <% ads.forEach(ad => { %>

    <a 
      href="/<%= country.slug %>/<%= location.slug %>/<%= category.slug %>/<%= category.id %>/<%= subcategory.slug %>/<%= subcategory.id %>/<%= ad.id %>"
      class="
        block p-8 rounded-xl
        bg-slate-900/30 border border-slate-800/50 backdrop-blur-xl
        text-slate-200
        hover:border-pink-500/80
        hover:shadow-[0_0_35px_rgba(236,72,153,0.5)]
        transition-all duration-500
      "
    >
      <h2 class="text-3xl font-semibold mb-3">
        <%= ad.title %>
      </h2>

      <p class="text-slate-400 leading-relaxed mb-4">
        <%= ad.description.substring(0, 150) %>...
      </p>

      <p class="text-xs text-slate-500 italic">
        Posted on <%= new Date(ad.created_at).toLocaleDateString() %>
      </p>
    </a>

  <% }) %>

</div>

