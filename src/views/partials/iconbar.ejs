<div class="flex items-center gap-6">

  <!-- UNIVERSAL ICON WRAPPER -->
  <% const iconWrapper = "relative group flex items-center justify-center w-6 h-6"; %>
  <% const iconBtn = "absolute inset-0 cursor-pointer transition-all duration-200 ease-out hover:scale-125 hover:-translate-y-1 active:scale-95 drop-shadow-sm hover:drop-shadow-lg"; %>

  <!-- VIEW -->
  <div class="<%= iconWrapper %>">
    <a href="/ads/<%= ad.id %>" class="<%= iconBtn %> text-pink-300 hover:text-pink-200">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-full h-full" fill="none"
           viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
              d="M2.25 12c1.5-4.5 5.25-7.5 9.75-7.5s8.25 3 9.75 7.5c-1.5 4.5-5.25 7.5-9.75 7.5S3.75 16.5 2.25 12z" />
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
              d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
      </svg>
    </a>

    <%- include("tooltip", { text: "View ad" }) %>
  </div>

  <!-- EDIT -->
  <div class="<%= iconWrapper %>">
    <a href="/ads/<%= ad.id %>/edit" class="<%= iconBtn %> text-pink-300 hover:text-pink-200">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-full h-full" fill="none"
           viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
              d="M11 4h2m2.586 0a2 2 0 011.414.586l2.414 2.414a2 2 0 010 2.828l-8.486 8.486A2 2 0 0110.172 19H7a1 1 0 01-1-1v-3.172a2 2 0 01.586-1.414l8.486-8.486z" />
      </svg>
    </a>

    <%- include("tooltip", { text: "Edit ad" }) %>
  </div>

  <!-- DELETE -->
  <div class="<%= iconWrapper %>">
    <button onclick="openDeleteModal(<%= ad.id %>, `<%- ad.title %>`)"
            class="<%= iconBtn %> text-red-400 hover:text-red-300">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-full h-full" fill="none"
           viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
              d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
      </svg>
    </button>

    <%- include("tooltip", { text: "Delete ad" }) %>
  </div>

</div>

