<div id="adForm" class="max-w-2xl mx-auto bg-gray-50 p-6 rounded shadow text-gray-800">

  <h1 class="text-2xl font-bold mb-4 text-gray-900">Add New Ad</h1>

  <form action="/ads/create" method="POST">
    <!-- CSRF token -->
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">

    <!-- Country -->
    <div class="mb-4">
      <label class="block font-semibold mb-1 text-gray-800">Country</label>
      <select class="w-full border border-gray-300 px-3 py-2 rounded bg-white text-gray-900"
              name="country_slug"
              v-model="selectedCountry">
        <option value="">Select Country</option>
        <option v-for="country in countries" :key="country.id" :value="country.slug">
          {{ country.name }}
        </option>
      </select>
    </div>

    <!-- City -->
    <div class="mb-4">
      <label class="block font-semibold mb-1 text-gray-800">City</label>
      <select class="w-full border border-gray-300 px-3 py-2 rounded bg-white text-gray-900"
              name="location_id"
              v-model="selectedCity" :disabled="!selectedCountry">
        <option value="">Select City</option>
        <option v-for="city in cities" :key="city.id" :value="city.id">
          {{ city.name }}
        </option>
      </select>
    </div>

    <!-- Category -->
    <div class="mb-4">
      <label class="block font-semibold mb-1 text-gray-800">Category</label>
      <select class="w-full border border-gray-300 px-3 py-2 rounded bg-white text-gray-900"
              name="category_id"
              v-model="selectedCategory">
        <option value="">Select Category</option>
        <option v-for="cat in categories" :key="cat.id" :value="cat.id">
          {{ cat.name }}
        </option>
      </select>
    </div>

    <!-- Subcategory -->
    <div class="mb-4">
      <label class="block font-semibold mb-1 text-gray-800">Subcategory</label>
      <select class="w-full border border-gray-300 px-3 py-2 rounded bg-white text-gray-900"
              name="subcategory_id"
              v-model="selectedSubcategory" :disabled="!selectedCategory">
        <option value="">Select Subcategory</option>
        <option v-for="sub in subcategories" :key="sub.id" :value="sub.id">
          {{ sub.name }}
        </option>
      </select>
    </div>

    <!-- Ad Title -->
    <div class="mb-4">
      <label class="block font-semibold mb-1 text-gray-800">Title</label>
      <input type="text" name="title" v-model="title"
             class="w-full border border-gray-300 px-3 py-2 rounded bg-white text-gray-900"
             placeholder="Ad title">
    </div>

    <!-- Ad Description -->
    <div class="mb-4">
      <label class="block font-semibold mb-1 text-gray-800">Description</label>
      <textarea name="description" v-model="description"
                class="w-full border border-gray-300 px-3 py-2 rounded bg-white text-gray-900"
                rows="4"
                placeholder="Ad description"></textarea>
    </div>

    <!-- Submit -->
    <div>
      <button type="submit"
              class="bg-blue-600 text-white px-4 py-2 rounded hover:bg-blue-700">
        Add Ad
      </button>
    </div>

  </form>
</div>

<script>
Vue.createApp({
  data() {
    return {
      countries: [],
      cities: [],
      categories: [],
      subcategories: [],
      selectedCountry: '',
      selectedCity: '',
      selectedCategory: '',
      selectedSubcategory: '',
      title: '',
      description: ''
    }
  },
  watch: {
    selectedCountry(newCountry) {
      if (!newCountry) {
        this.cities = [];
        this.selectedCity = '';
        return;
      }
      fetch(`/api/cities?country=${newCountry}`)
        .then(res => res.json())
        .then(data => {
          this.cities = data;
          this.selectedCity = '';
        })
        .catch(err => console.error('Error loading cities:', err));
    },
    selectedCategory(newCategory) {
      if (!newCategory) {
        this.subcategories = [];
        this.selectedSubcategory = '';
        return;
      }
      fetch(`/api/subcategories?category=${newCategory}`)
        .then(res => res.json())
        .then(data => {
          this.subcategories = data;
          this.selectedSubcategory = '';
        })
        .catch(err => console.error('Error loading subcategories:', err));
    }
  },
  mounted() {
    console.log('Vue mounted successfully');
    // Load countries
    fetch('/api/countries')
      .then(res => res.json())
      .then(data => { this.countries = data; })
      .catch(err => console.error('Error loading countries:', err));

    // Load categories
    fetch('/api/categories')
      .then(res => res.json())
      .then(data => { this.categories = data; })
      .catch(err => console.error('Error loading categories:', err));
  }
}).mount('#adForm');
</script>
