<div id="adForm"
     data-ad-id="<%= adId %>"
     class="max-w-2xl mx-auto bg-gray-50 p-6 rounded shadow text-gray-800">

  <h1 class="text-2xl font-bold mb-4 text-gray-900">Edit Ad</h1>

  <form @submit.prevent="saveAd">

    <!-- Country -->
    <div class="mb-4">
      <label class="block font-semibold mb-1 text-gray-800">Country</label>
      <select v-model="selectedCountry"
              class="w-full border border-gray-300 px-3 py-2 rounded bg-white text-gray-900">
        <option value="">Select Country</option>
        <option v-for="country in countries" :value="country.slug">
          {{ country.name }}
        </option>
      </select>
    </div>

    <!-- Location -->
    <div class="mb-4">
      <label class="block font-semibold mb-1 text-gray-800">Location</label>
      <select v-model="selectedLocation"
              :disabled="!selectedCountry"
              class="w-full border border-gray-300 px-3 py-2 rounded bg-white text-gray-900">
        <option value="">Select Location</option>
        <option v-for="loc in locations" :value="loc.id">
          {{ loc.name }}
        </option>
      </select>
    </div>

    <!-- Category -->
    <div class="mb-4">
      <label class="block font-semibold mb-1 text-gray-800">Category</label>
      <select v-model="selectedCategory"
              class="w-full border border-gray-300 px-3 py-2 rounded bg-white text-gray-900">
        <option value="">Select Category</option>
        <option v-for="cat in categories" :value="cat.id">
          {{ cat.name }}
        </option>
      </select>
    </div>

    <!-- Subcategory -->
    <div class="mb-4">
      <label class="block font-semibold mb-1 text-gray-800">Subcategory</label>
      <select v-model="selectedSubcategory"
              :disabled="!selectedCategory"
              class="w-full border border-gray-300 px-3 py-2 rounded bg-white text-gray-900">
        <option value="">Select Subcategory</option>
        <option v-for="sub in subcategories" :value="sub.id">
          {{ sub.name }}
        </option>
      </select>
    </div>

    <!-- Title -->
    <div class="mb-4">
      <label class="block font-semibold mb-1 text-gray-800">Title</label>
      <input type="text"
             v-model="title"
             class="w-full border border-gray-300 px-3 py-2 rounded bg-white text-gray-900"
             placeholder="Ad title">
    </div>

    <!-- Description -->
    <div class="mb-4">
      <label class="block font-semibold mb-1 text-gray-800">Description</label>
      <textarea v-model="description"
                class="w-full border border-gray-300 px-3 py-2 rounded bg-white text-gray-900"
                rows="4"
                placeholder="Ad description"></textarea>
    </div>

    <button type="submit"
            class="bg-blue-600 text-white px-4 py-2 rounded hover:bg-blue-700">
      Save Changes
    </button>
  </form>
</div>

<script>
const el = document.getElementById("adForm");

Vue.createApp({
  data() {
    return {
      adId: el.dataset.adId,

      countries: [],
      locations: [],
      categories: [],
      subcategories: [],

      selectedCountry: "",
      selectedLocation: "",
      selectedCategory: "",
      selectedSubcategory: "",
      title: "",
      description: ""
    };
  },

  async mounted() {
    await Promise.all([
      this.loadCountries(),
      this.loadCategories()
    ]);

    await this.loadAd();
  },

  watch: {
    selectedCountry(newVal) {
      if (newVal) this.loadLocations(newVal);
    },
    selectedCategory(newVal) {
      if (newVal) this.loadSubcategories(newVal);
    }
  },

  methods: {
    async loadCountries() {
      this.countries = await fetch('/api/countries', {
        credentials: "include"
      }).then(r => r.json());
    },

    async loadCategories() {
      this.categories = await fetch('/api/categories', {
        credentials: "include"
      }).then(r => r.json());
    },

    async loadLocations(countrySlug) {
      this.locations = await fetch(`/api/locations?country=${countrySlug}`, {
        credentials: "include"
      }).then(r => r.json());
    },

    async loadSubcategories(categoryId) {
      this.subcategories = await fetch(`/api/subcategories?category=${categoryId}`, {
        credentials: "include"
      }).then(r => r.json());
    },

    async loadAd() {
      const ad = await fetch(`/api/ad/${this.adId}`, {
        credentials: "include"
      }).then(r => r.json());

      this.title = ad.title;
      this.description = ad.description;

      this.selectedCountry = ad.country_slug;
      await this.loadLocations(ad.country_slug);

      this.selectedCategory = ad.category_id;
      await this.loadSubcategories(ad.category_id);

      this.selectedLocation = ad.location_id;
      this.selectedSubcategory = ad.subcategory_id;
    },

    async saveAd() {
      const payload = {
        title: this.title,
        description: this.description,
        category_id: this.selectedCategory,
        subcategory_id: this.selectedSubcategory,
        location_id: this.selectedLocation
      };

      const res = await fetch(`/api/ad/${this.adId}`, {
        method: "PUT",
        headers: {
          "Content-Type": "application/json",
          "Accept": "application/json"
        },
        credentials: "include",
        body: JSON.stringify(payload)
      });

      const data = await res.json();
      console.log("UPDATE RESPONSE:", data);

      if (!res.ok) {
        alert("Update failed: " + JSON.stringify(data));
        return;
      }

      window.location.href = "/dashboard";
    }
  }
}).mount('#adForm');
</script>

